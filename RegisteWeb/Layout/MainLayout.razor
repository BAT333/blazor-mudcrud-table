@inherits LayoutComponentBase

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Color="Color.Surface" Fixed="true" Elevation="2">
        <MudImage Src="images/logo.png"
                  Width="40"
                  Height="40"
                  Alt="Logo"
                  ObjectFit="ObjectFit.Contain"
                  Class="ma-2" />

        <AuthorizeView>
            <Authorized>
                <MudAvatar Color="Color.Default">
                    <MudIcon Icon="@Icons.Material.Filled.Person"></MudIcon>
                </MudAvatar>
                <MudButton Class="ml-4" Href="logout"
                           Variant="Variant.Outlined"
                           Color="Color.Default">Logout</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Class="ml-4" Href="login"
                           Variant="Variant.Outlined"
                           Color="Color.Default">Login</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer Open="true" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu></NavMenu>
    </MudDrawer>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>