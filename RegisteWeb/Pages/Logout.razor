@inject AuthCustomerApiService authCustomerApiService;
@page "/logout"
@attribute [AllowAnonymous]


@code {

	protected override async Task OnInitializedAsync()
	{
		var verificationAuthenticated = await authCustomerApiService.VerificationAuthenticated();
		if (verificationAuthenticated)
		{
			await this.authCustomerApiService.LogoutAsync();
		}
	}
}
